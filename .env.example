# morning-cli — credential template
#
# The easiest way to set up credentials is:
#   morning-cli auth init
#
# The wizard walks you through the process and saves to
# ~/.greeninvoice/credentials.json (mode 0600). This file is only needed
# for non-interactive setups (CI, Docker, scripts).
#
# Copy to `.env` (gitignored) or export directly in your shell.
# Do NOT commit real credentials. The SECRET is shown only once when you
# create an API key in your morning account — treat it like a password.

# Required — preferred MORNING_* prefix
MORNING_API_KEY_ID=
MORNING_API_KEY_SECRET=

# Optional — environment selection (default: sandbox)
# Values: sandbox | production
MORNING_ENV=sandbox

# Optional — override the base URL entirely (for proxies / custom deployments)
# MORNING_BASE_URL=https://sandbox.d.greeninvoice.co.il/api/v1

# --- Legacy fallback prefix (still supported for backwards compat) ---
# GREENINVOICE_API_KEY_ID=
# GREENINVOICE_API_KEY_SECRET=
# GREENINVOICE_ENV=sandbox

# --- Test-suite credentials (for E2E against the real sandbox) ---
# Read by the pytest suite in test_full_e2e.py. Keep separate from your
# main dev credentials so test runs can't clobber your real session.
MORNING_SANDBOX_ID=
MORNING_SANDBOX_SECRET=
